# Equiti-AI Environment Variables
# Copy this file to .env and fill in your keys

# Required: Anthropic API key for memo generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: GitHub personal access token (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=your_github_token_here

# Optional: Crunchbase API key for deal-flow data
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# Optional: Proxycurl API key for LinkedIn/hiring velocity data
PROXYCURL_API_KEY=your_proxycurl_api_key_here

# Data mode safety flag — never set to False in MVP
SAFE_MODE=True
